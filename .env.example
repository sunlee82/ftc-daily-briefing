# 실제 키는 이 파일을 .env로 복사한 뒤 값을 채워 넣으세요.
# .env는 .gitignore에 등록되어 있어 커밋되지 않습니다.

# 웹/뉴스 검색 — serper.dev (필수: 없으면 수집 단계에서 오류)
SERPER_API_KEY=

# Claude API — 요약 (선택)
# 웹 도구(localhost:4173)의 [브리핑 생성] 버튼으로 자동 요약할 때만 필요합니다.
# Claude Code(구독)로 직접 요약해서 발행하는 방식(tool/pipeline/collectRaw.js
# 사용)을 쓸 거라면 이 키는 없어도 됩니다. ANTHROPIC_API_KEY로도 대체 가능합니다.
CLAUDE_API_KEY=

# 요약에 쓸 Claude 모델 (선택, 기본값 claude-opus-4-8)
CLAUDE_MODEL=

# 서버 포트 (선택, 기본값 4173)
PORT=
